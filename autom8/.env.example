# AutoM8 Configuration — copy to .env and fill in values
# docker compose reads this file automatically via env_file directive

# Ports (defaults shown — change if conflicts)
FRONTEND_PORT=3000
API_PORT=8000

# AI (leave empty to use template-only mode without AI recommendations)
ANTHROPIC_API_KEY=

# SentinelOne — optional, features hidden until configured (Phase 6)
S1_HYPERAUTOMATION_API_KEY=
S1_HYPERAUTOMATION_URL=
S1_CONFIG_API_KEY=
S1_CONFIG_URL=

# Auth — reserved for future use
DISABLE_AUTH=true
